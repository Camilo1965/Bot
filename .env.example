# ── Execution mode ────────────────────────────────────────────────────────────
# Controls which execution backend the bot uses at startup.
#
#   mt5        – MetaTrader 5 via the MT5Executor (requires a running MT5
#                terminal and the credentials below).
#   paper      – Pure paper-trading simulation (default, no broker needed).
#   testnet    – Binance Futures Testnet (requires EXCHANGE_API_KEY/SECRET).
#   live       – Binance Futures live API  (requires EXCHANGE_API_KEY/SECRET).
#
EXECUTION_MODE=mt5

# ── MetaTrader 5 credentials (used when EXECUTION_MODE=mt5) ───────────────────
# MT5_LOGIN must be an integer account number.
# MT5_SERVER must match the server name shown in the MT5 terminal exactly.
MT5_LOGIN=your_mt5_login
MT5_PASSWORD=your_mt5_password
MT5_SERVER=AdmiralsSC-Demo

# ── Binance exchange credentials (used when EXECUTION_MODE=testnet or live) ───
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_SECRET=your_api_secret_here

# ── Legacy Binance trading-mode flags (ignored when EXECUTION_MODE=mt5) ───────
# Set USE_BINANCE_TESTNET=True to route orders to the Binance Futures Testnet
# (https://testnet.binancefuture.com) and fetch the real testnet wallet balance.
# This takes priority over PAPER_TRADING when both are True.
USE_BINANCE_TESTNET=False

# Set PAPER_TRADING=False to route orders to the Binance Futures live API.
# Ignored when USE_BINANCE_TESTNET=True.
PAPER_TRADING=True

# ── Database (PostgreSQL / TimescaleDB) ────────────────────────────────────────
DB_USER=clawdbot
DB_PASSWORD=clawdbot_secret
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clawdbot

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Gemini LLM (sentiment analysis) ───────────────────────────────────────────
GEMINI_API_KEY=

# ── Telegram notifications ─────────────────────────────────────────────────────
# Create a bot via @BotFather and obtain the token, then get your chat ID by
# messaging @userinfobot.  Leave blank to disable Telegram alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
