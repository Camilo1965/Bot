# ── Execution mode ────────────────────────────────────────────────────────────
# mt5  – MetaTrader 5 (requires running MT5 terminal + credentials below).
# paper – Internal simulation only (bot will exit: market feed requires MT5).
EXECUTION_MODE=mt5

# ── MetaTrader 5 (required when EXECUTION_MODE=mt5) ───────────────────────────
# MT5_LOGIN: integer account number. MT5_SERVER: exact name shown in MT5.
MT5_LOGIN=your_mt5_login
MT5_PASSWORD=your_mt5_password
MT5_SERVER=YourBroker-Demo

# ── Database (PostgreSQL; hypertables need TimescaleDB extension) ─────────────
DB_USER=clawdbot
DB_PASSWORD=clawdbot_secret
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clawdbot

# ── Redis (optional for this codebase path; not required by main.py) ──────────
REDIS_URL=redis://localhost:6379/0

# ── Gemini LLM (sentiment; optional — bot uses neutral baseline if empty) ─────
GEMINI_API_KEY=

# ── Telegram (optional alerts) ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
